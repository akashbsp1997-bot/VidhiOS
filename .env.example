# Copy this file to .env.local for local development.
# In production, set these as Environment Variables in your Vercel project settings.

# Supabase Postgres connection string — use the "Connection pooling" (pgbouncer,
# port 6543) string from Supabase Project Settings -> Database for serverless/Vercel.
DATABASE_URL="postgresql://postgres.xxxxx:[email protected]:6543/postgres"

# Your own OpenRouter API key — https://openrouter.ai/keys
# Required for AI grading (fires on every submitted answer) and model-question
# generation (fires occasionally). Defaults to a free OpenRouter model
# (deepseek/deepseek-chat-v3.1:free), so no billing is required to try this.
# See README "Costs" section and lib/ai/client.js to change the model.
OPENROUTER_API_KEY="sk-or-..."

# Optional: protects /api/cron/refresh-sources from being triggered by anyone
# who finds the URL. Generate any random string, set the same value in Vercel's
# cron configuration / environment variables.
CRON_SECRET="choose-any-random-string"

# Required to run the one-time browser setup at /api/setup?key=... (creates
# tables + seeds data with no terminal needed). Any random string works —
# just remember it, you'll paste it into the URL once.
SETUP_SECRET="choose-another-random-string"
