# Copy this file to .env.local for local development.
# In production, set these as Environment Variables in your Vercel project settings.

# Supabase Postgres connection string — use the "Connection pooling" (pgbouncer,
# port 6543) string from Supabase Project Settings -> Database for serverless/Vercel.
DATABASE_URL="postgresql://postgres.xxxxx:[email protected]:6543/postgres"

# Your own Google AI Studio key — https://aistudio.google.com/apikey (free,
# no card required to create one). Required for AI grading (fires on every
# submitted answer), model-question generation, lesson generation, and
# diagram image generation -- called directly against Google's Gemini API
# (gemini-3.5-flash text, gemini-3.1-flash-image images), not through
# OpenRouter. See README "Costs" section and lib/ai/client.js to change the
# models. Free tier has daily/per-minute quotas that vary by model and can
# change without notice -- see https://ai.google.dev/gemini-api/docs/rate-limits
# for current numbers; a quota-exceeded call fails with a clear error, it
# doesn't hang or silently degrade.
GOOGLE_AI_API_KEY="AIza..."

# Optional -- your own Groq key: https://console.groq.com/keys (free, no
# card required). If set, callClaudeForJSON (grading/questions/lessons --
# not image generation, Groq doesn't serve one) automatically falls back to
# Groq's openai/gpt-oss-120b whenever Gemini fails for any reason (a demand
# spike outlasting its own retries, its free-tier quota exhausted, etc.) --
# a fully separate account/quota/infrastructure from Google's. Leave unset
# to keep the previous behavior exactly (Gemini's own error surfaces
# directly, no fallback attempted). See lib/ai/client.js.
GROQ_API_KEY="gsk_..."

# Supabase project URL and anon (public) key — Project Settings -> API.
# Required for account sign-in/sign-up (email/password). The anon key is
# safe to expose to the browser by design; do not use the service role key
# here.
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase service role (secret) key — Project Settings -> API -> service_role.
# Bypasses Row Level Security. Required ONLY for the content-ingestion pipeline
# (app/api/setup/storage, app/api/ingest/*) to read/write the private
# "ingest-uploads" Storage bucket. Server-side only — never prefix this with
# NEXT_PUBLIC_, never import it into a Client Component or any browser code path.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Optional: protects /api/cron/refresh-sources and /api/cron/send-reminders
# from being triggered by anyone who finds the URL. Generate any random
# string, set the same value in Vercel's cron configuration / environment
# variables.
CRON_SECRET="choose-any-random-string"

# Optional -- your own Resend key: https://resend.com/api-keys (free tier,
# 3,000 emails/month, no card required). If set, /api/cron/send-reminders
# (runs daily via vercel.json) emails every onboarded user their day-wise
# plan for today. Leave unset to skip reminder emails entirely -- the cron
# route no-ops with a clear message rather than erroring. Emails send from
# Resend's shared "onboarding@resend.dev" address unless you verify your
# own domain in the Resend dashboard and set RESEND_FROM_EMAIL below.
RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="VidhiOS Adaptive <you@yourdomain.com>"

# Optional -- your own NewsData.io key: https://newsdata.io/register (free
# tier, 200 credits/day, no card required). If set,
# /api/cron/fetch-current-affairs (runs daily via vercel.json) pulls
# India-focused news, condenses it into exam-relevant summaries, and tags it
# against real syllabus subtopics -- all in one batched AI call per run.
# Leave unset to skip the current-affairs digest entirely.
NEWSDATA_API_KEY="pub_..."

# Required to run the one-time browser setup at /api/setup?key=... (creates
# tables + seeds data with no terminal needed). Any random string works —
# just remember it, you'll paste it into the URL once.
SETUP_SECRET="choose-another-random-string"
